# ============================================================
# LOGI SEO Booster / AI Marketing Agent — VPS production
# Copier ce fichier vers .env puis remplacer toutes les valeurs CHANGE_ME
# NE JAMAIS commiter le fichier .env réel dans Git
# ============================================================

APP_NAME=LOGI SEO Booster
APP_ENV=production
COMPOSE_PROJECT_NAME=logiseo

# --- URL publique (domaine final) ---
PUBLIC_URL=https://seo.logitrak.ch
CORS_ORIGINS=https://seo.logitrak.ch

# --- MongoDB (conteneur logiseo_mongodb, jamais exposé publiquement) ---
MONGO_ROOT_USER=logiseo_app
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=logiseo_prod

# --- Auth ---
JWT_SECRET=CHANGE_ME_64_RANDOM_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# --- Chiffrement at-rest des tokens utilisateurs (Fernet) ---
# Generer avec : python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# --- IA (IMPORTANT : la cle Emergent ne fonctionne PAS hors plateforme Emergent) ---
# Mettre ici votre propre cle Anthropic (sk-ant-...) obtenue sur console.anthropic.com
# Elle alimente Claude (generation, analyses). Les tests de citation ChatGPT/Gemini
# du module AI Visibility seront marques "indisponibles" sans cles OpenAI/Google.
EMERGENT_LLM_KEY=CHANGE_ME_SK_ANT_KEY

# --- Stripe (votre propre compte : cle test sk_test_... ou live sk_live_...) ---
STRIPE_API_KEY=CHANGE_ME

# --- Google Search Console / Analytics OAuth (console.cloud.google.com) ---
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME
GOOGLE_OAUTH_REDIRECT_URI=https://seo.logitrak.ch/api/google/oauth/callback

# --- LinkedIn OAuth (developer.linkedin.com) ---
LINKEDIN_CLIENT_ID=CHANGE_ME
LINKEDIN_CLIENT_SECRET=CHANGE_ME
LINKEDIN_REDIRECT_URI=https://seo.logitrak.ch/api/linkedin/oauth/callback

# --- Meta / Facebook + Instagram (developers.facebook.com) ---
# Creer une app Meta type "Business", ajouter le produit "Facebook Login for Business",
# whitelister l'URI de redirection ci-dessous, puis demander les permissions :
# pages_show_list, pages_manage_posts, instagram_basic, instagram_content_publish, business_management
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME
META_REDIRECT_URI=https://seo.logitrak.ch/api/meta/oauth/callback

# --- Google Business Profile (console.cloud.google.com) ---
# Peut reutiliser GOOGLE_OAUTH_CLIENT_ID/SECRET (laisser GBP_CLIENT_ID/SECRET vides dans ce cas).
# IMPORTANT : les API Business Profile necessitent une demande d'acces approuvee par Google
# (formulaire "Business Profile APIs access request") + activer : My Business Account Management API,
# My Business Business Information API, Google My Business API (v4).
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REDIRECT_URI=https://seo.logitrak.ch/api/gbp/oauth/callback

# --- Pexels (photos de couverture des articles — cle 100% gratuite sur pexels.com/api) ---
PEXELS_API_KEY=CHANGE_ME
